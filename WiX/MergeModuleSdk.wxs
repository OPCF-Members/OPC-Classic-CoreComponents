        <?define g_OpcCmdPs_dll = "C3D484BD-B570-D103-36B6-3805E92D66EC" ?>
        <?define g_OpcDxPs_dll = "F440E3B6-1079-206D-29F9-BE3870968F79" ?>
        <?define g_opchda_ps_dll = "4BAE66D4-DF99-EA23-2B34-5439F587C62E" ?>
        <?define g_opcsec_ps_dll = "01F4C181-D968-B1FA-5495-FA9B2CAF54F4" ?>
