        <?define g_OpcBatchError_h = "758D4F8F-D173-4911-8ABC-0851AD26B436" ?>
        <?define g_OpcBatchProps_h = "A27EAAFA-5F81-43C7-BD55-B4241FA48B19" ?>
        <?define g_OpcBatchDef_h = "D9A6F681-AEF7-44B3-9F3B-5DE658BB64C3" ?>
