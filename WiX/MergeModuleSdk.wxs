    <Module Id="MergeModuleSdk"
            Guid="$(var.SdkGuid)"
            Language="1033"
            Version="$(var.Version)">

        <SummaryInformation
            Description="OPC COM SDK Merge Module $(var.PlatformTag)"
            Manufacturer="OPC Foundation" />

        <?if $(var.Platform) = x86 ?>
        <StandardDirectory Id="CommonFilesFolder">
        <?else?>
        <StandardDirectory Id="CommonFiles64Folder">
        <?endif?>
            <Directory Id="OPCFoundationSdkFolder" Name="OPC Foundation">
                <Directory Id="OPCIncludeFolder" Name="Include">

                    <!-- OPC Common -->
                    <Component Id="sdk_opccomn_h" Guid="$(var.g_opccomn_h)">
                        <File Id="file_sdk_opccomn_h"
                              Name="opccomn.h"
                              Source="$(var.IncludeDir)\opccomn.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opccomn_i" Guid="$(var.g_opccomn_i)">
                        <File Id="file_sdk_opccomn_i"
                              Name="opccomn_i.c"
                              Source="$(var.IncludeDir)\opccomn_i.c"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opccomn_idl" Guid="$(var.g_opccomn_idl)">
                        <File Id="file_sdk_opccomn_idl"
                              Name="opccomn.idl"
                              Source="$(var.IncludeDir)\opccomn.idl"
                              KeyPath="yes" />
                    </Component>

                    <!-- OPC Data Access -->
                    <Component Id="sdk_opcda_h" Guid="$(var.g_opcda_h)">
                        <File Id="file_sdk_opcda_h"
                              Name="opcda.h"
                              Source="$(var.IncludeDir)\opcda.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcda_i" Guid="$(var.g_opcda_i)">
                        <File Id="file_sdk_opcda_i"
                              Name="opcda_i.c"
                              Source="$(var.IncludeDir)\opcda_i.c"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcda_idl" Guid="$(var.g_opcda_idl)">
                        <File Id="file_sdk_opcda_idl"
                              Name="opcda.idl"
                              Source="$(var.IncludeDir)\opcda.idl"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcerror_h" Guid="$(var.g_opcerror_h)">
                        <File Id="file_sdk_opcerror_h"
                              Name="opcerror.h"
                              Source="$(var.IncludeDir)\opcerror.h"
                              KeyPath="yes" />
                    </Component>

                    <!-- OPC Alarms & Events -->
                    <Component Id="sdk_opc_ae_h" Guid="$(var.g_opc_ae_h)">
                        <File Id="file_sdk_opc_ae_h"
                              Name="opc_ae.h"
                              Source="$(var.IncludeDir)\opc_ae.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opc_ae_i" Guid="$(var.g_opc_ae_i)">
                        <File Id="file_sdk_opc_ae_i"
                              Name="opc_ae_i.c"
                              Source="$(var.IncludeDir)\opc_ae_i.c"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opc_ae_idl" Guid="$(var.g_opc_ae_idl)">
                        <File Id="file_sdk_opc_ae_idl"
                              Name="opc_ae.idl"
                              Source="$(var.IncludeDir)\opc_ae.idl"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcae_er_h" Guid="$(var.g_opcae_er_h)">
                        <File Id="file_sdk_opcae_er_h"
                              Name="opcae_er.h"
                              Source="$(var.IncludeDir)\opcae_er.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcaedef_h" Guid="$(var.g_opcaedef_h)">
                        <File Id="file_sdk_opcaedef_h"
                              Name="opcaedef.h"
                              Source="$(var.IncludeDir)\opcaedef.h"
                              KeyPath="yes" />
                    </Component>

                    <!-- OPC Batch -->
                    <Component Id="sdk_opcbc_h" Guid="$(var.g_opcbc_h)">
                        <File Id="file_sdk_opcbc_h"
                              Name="opcbc.h"
                              Source="$(var.IncludeDir)\opcbc.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcbc_i" Guid="$(var.g_opcbc_i)">
                        <File Id="file_sdk_opcbc_i"
                              Name="opcbc_i.c"
                              Source="$(var.IncludeDir)\opcbc_i.c"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcbc_idl" Guid="$(var.g_opcbc_idl)">
                        <File Id="file_sdk_opcbc_idl"
                              Name="opcbc.idl"
                              Source="$(var.IncludeDir)\opcbc.idl"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcBatchError_h" Guid="$(var.g_OpcBatchError_h)">
                        <File Id="file_sdk_OpcBatchError_h"
                              Name="OpcBatchError.h"
                              Source="$(var.IncludeDir)\OpcBatchError.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcBatchProps_h" Guid="$(var.g_OpcBatchProps_h)">
                        <File Id="file_sdk_OpcBatchProps_h"
                              Name="OpcBatchProps.h"
                              Source="$(var.IncludeDir)\OpcBatchProps.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcBatchDef_h" Guid="$(var.g_OpcBatchDef_h)">
                        <File Id="file_sdk_OpcBatchDef_h"
                              Name="OpcBatchDef.h"
                              Source="$(var.IncludeDir)\OpcBatchDef.h"
                              KeyPath="yes" />
                    </Component>

                    <!-- OPC Commands -->
                    <Component Id="sdk_OpcCmd_h" Guid="$(var.g_OpcCmd_h)">
                        <File Id="file_sdk_OpcCmd_h"
                              Name="OpcCmd.h"
                              Source="$(var.IncludeDir)\OpcCmd.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcCmd_i" Guid="$(var.g_OpcCmd_i)">
                        <File Id="file_sdk_OpcCmd_i"
                              Name="OpcCmd_i.c"
                              Source="$(var.IncludeDir)\OpcCmd_i.c"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcCmd_idl" Guid="$(var.g_OpcCmd_idl)">
                        <File Id="file_sdk_OpcCmd_idl"
                              Name="OpcCmd.idl"
                              Source="$(var.IncludeDir)\OpcCmd.idl"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcCmdError_h" Guid="$(var.g_OpcCmdError_h)">
                        <File Id="file_sdk_OpcCmdError_h"
                              Name="OpcCmdError.h"
                              Source="$(var.IncludeDir)\OpcCmdError.h"
                              KeyPath="yes" />
                    </Component>

                    <!-- OPC Data Exchange -->
                    <Component Id="sdk_OpcDx_h" Guid="$(var.g_OpcDx_h)">
                        <File Id="file_sdk_OpcDx_h"
                              Name="OpcDx.h"
                              Source="$(var.IncludeDir)\OpcDx.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcDx_i" Guid="$(var.g_OpcDx_i)">
                        <File Id="file_sdk_OpcDx_i"
                              Name="OpcDx_i.c"
                              Source="$(var.IncludeDir)\OpcDx_i.c"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcDx_idl" Guid="$(var.g_OpcDx_idl)">
                        <File Id="file_sdk_OpcDx_idl"
                              Name="OpcDx.idl"
                              Source="$(var.IncludeDir)\OpcDx.idl"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcDxError_h" Guid="$(var.g_OpcDxError_h)">
                        <File Id="file_sdk_OpcDxError_h"
                              Name="OpcDxError.h"
                              Source="$(var.IncludeDir)\OpcDxError.h"
                              KeyPath="yes" />
                    </Component>

                    <!-- OPC Historical Data Access -->
                    <Component Id="sdk_opchda_h" Guid="$(var.g_opchda_h)">
                        <File Id="file_sdk_opchda_h"
                              Name="opchda.h"
                              Source="$(var.IncludeDir)\opchda.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opchda_i" Guid="$(var.g_opchda_i)">
                        <File Id="file_sdk_opchda_i"
                              Name="opchda_i.c"
                              Source="$(var.IncludeDir)\opchda_i.c"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opchda_idl" Guid="$(var.g_opchda_idl)">
                        <File Id="file_sdk_opchda_idl"
                              Name="opchda.idl"
                              Source="$(var.IncludeDir)\opchda.idl"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcHda_Error_h" Guid="$(var.g_OpcHda_Error_h)">
                        <File Id="file_sdk_OpcHda_Error_h"
                              Name="OpcHda_Error.h"
                              Source="$(var.IncludeDir)\OpcHda_Error.h"
                              KeyPath="yes" />
                    </Component>

                    <!-- OPC Security -->
                    <Component Id="sdk_opcSec_h" Guid="$(var.g_opcSec_h)">
                        <File Id="file_sdk_opcSec_h"
                              Name="opcSec.h"
                              Source="$(var.IncludeDir)\opcSec.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcSec_i" Guid="$(var.g_opcSec_i)">
                        <File Id="file_sdk_opcSec_i"
                              Name="opcSec_i.c"
                              Source="$(var.IncludeDir)\opcSec_i.c"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcSec_idl" Guid="$(var.g_opcSec_idl)">
                        <File Id="file_sdk_opcSec_idl"
                              Name="opcSec.idl"
                              Source="$(var.IncludeDir)\opcSec.idl"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcErrSec_h" Guid="$(var.g_OpcErrSec_h)">
                        <File Id="file_sdk_OpcErrSec_h"
                              Name="OpcErrSec.h"
                              Source="$(var.IncludeDir)\OpcErrSec.h"
                              KeyPath="yes" />
                    </Component>

                    <!-- OPC Enum (x86 only) -->
                    <?if $(var.Platform) = x86 ?>
                    <Component Id="sdk_OpcEnum_h" Guid="$(var.g_OpcEnum_h)">
                        <File Id="file_sdk_OpcEnum_h"
                              Name="OpcEnum.h"
                              Source="$(var.IncludeDir)\OpcEnum.h"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcEnum_i" Guid="$(var.g_OpcEnum_i)">
                        <File Id="file_sdk_OpcEnum_i"
                              Name="OpcEnum_i.c"
                              Source="$(var.IncludeDir)\OpcEnum_i.c"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_OpcEnum_idl" Guid="$(var.g_OpcEnum_idl)">
                        <File Id="file_sdk_OpcEnum_idl"
                              Name="OpcEnum.idl"
                              Source="$(var.IncludeDir)\OpcEnum.idl"
                              KeyPath="yes" />
                    </Component>
                    <?endif?>

                    <!-- Reference copies of proxy/stub DLLs -->
                    <Component Id="sdk_opccomn_ps_dll" Guid="$(var.g_opccomn_ps_dll)">
                        <File Id="file_sdk_opccomn_ps_dll"
                              Name="opccomn_ps.dll"
                              Source="$(var.IncludeDir)\opccomn_ps.dll"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opcproxy_dll" Guid="$(var.g_opcproxy_dll)">
                        <File Id="file_sdk_opcproxy_dll"
                              Name="opcproxy.dll"
                              Source="$(var.IncludeDir)\opcproxy.dll"
                              KeyPath="yes" />
                    </Component>
                    <Component Id="sdk_opc_aeps_dll" Guid="$(var.g_opc_aeps_dll)">
                        <File Id="file_sdk_opc_aeps_dll"
                              Name="opc_aeps.dll"
                              Source="$(var.IncludeDir)\opc_aeps.dll"
                              KeyPath="yes" />
