<?xml version="1.0" encoding="UTF-8"?>
<!--
    OPC Core Components - COM Proxy/Stub Merge Module

    This merge module packages all 8 OPC COM proxy/stub DLLs,
    plus OpcEnum.exe (x86) or OpcCategoryManager.exe (x64),
    with COM self-registration.

    SDK development files (headers, IDLs, IID files) are in a separate
    SDK merge module (MergeModuleSdk.wxs).

    Target locations (matching original OPC Foundation installer):
      x86: 6 core DLLs + OpcEnum.exe to SystemFolder
           OpcCmdPs + OpcDxPs to CommonFilesFolder\OPC Foundation\Bin
      x64: all 8 DLLs + OpcCategoryManager.exe to CommonFiles64Folder\OPC Foundation\Bin

    Component GUIDs: these are the ORIGINAL OPC Foundation (3.00.108) per-file,
    per-platform component GUIDs, recovered from the legacy merge modules. They
    are distinct between x86 and x64 (each physical file in each location is a
    distinct component) which both satisfies ICE08 and preserves shared-component
    reference counting with the deployed install base. DO NOT make x86 and x64
    share a GUID, and DO NOT regenerate these - changing them breaks upgrade and
    cross-product reference counting for everyone who ships these modules.

    Uninstall leftover (x86 in the combined x64 MSI): the 32-bit core DLLs install
    into SystemFolder, so in the combined x64 MSI WIN64DUALFOLDERS makes Windows
    Installer resolve those components to Action: Null on uninstall and leave the
    SysWOW64 copies on disk. This module deliberately keeps plain, standard authoring
    (no RemoveFile / SharedDLLs custom actions - earlier attempts to force the removal
    inside the MSI broke clean install/uninstall). Those leftovers are removed on
    demand by Cleanup-OpcCoreComponents.ps1 instead.

    Platform-specific variables (passed via -d):
      BinDir      - path to compiled DLLs
      ModuleGuid  - merge module GUID (x86 vs x64)
      PlatformTag - display tag, e.g. "(x86)" or "(x64)"
      Platform    - target platform: x86 or x64
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

    <Module Id="MergeModule"
            Guid="$(var.ModuleGuid)"
            Language="1033"
            Version="$(var.Version)">

        <SummaryInformation
            Description="OPC COM Proxy/Stub Merge Module $(var.PlatformTag)"
            Manufacturer="OPC Foundation" />

        <?if $(var.Platform) = x86 ?>
        <!--
            x86: 6 core proxy/stub DLLs + OpcEnum.exe go to SystemFolder
        -->
        <StandardDirectory Id="SystemFolder">

            <Component Id="comp_opccomn_ps" Guid="1902BC04-D8CF-67CE-FC28-9C8635C5C2D0">
                <File Id="file_opccomn_ps"
                      Name="opccomn_ps.dll"
                      Source="$(var.BinDir)\opccomn_ps.dll"
                      KeyPath="yes"
                      SelfRegCost="1" />
            </Component>

            <Component Id="comp_opcproxy" Guid="3C257474-772A-6CE8-282E-7F4413643C2C">
                <File Id="file_opcproxy"
                      Name="opcproxy.dll"
                      Source="$(var.BinDir)\opcproxy.dll"
                      KeyPath="yes"
                      SelfRegCost="1" />
            </Component>

            <Component Id="comp_opc_aeps" Guid="CD1FB489-1F99-28C2-058C-D7D3E7740F3B">
                <File Id="file_opc_aeps"
                      Name="opc_aeps.dll"
                      Source="$(var.BinDir)\opc_aeps.dll"
                      KeyPath="yes"
                      SelfRegCost="1" />
            </Component>

            <Component Id="comp_opcbc_ps" Guid="531CABFE-03FC-439E-EB24-DEBB3AD7792B">
                <File Id="file_opcbc_ps"
                      Name="opcbc_ps.dll"
                      Source="$(var.BinDir)\opcbc_ps.dll"
                      KeyPath="yes"
                      SelfRegCost="1" />
            </Component>

            <Component Id="comp_opchda_ps" Guid="69CC9D6E-4B05-F7A4-3D9B-5D771F36DB4E">
                <File Id="file_opchda_ps"
                      Name="opchda_ps.dll"
                      Source="$(var.BinDir)\opchda_ps.dll"
                      KeyPath="yes"
                      SelfRegCost="1" />
            </Component>

            <Component Id="comp_opcsec_ps" Guid="2F6FBEF4-D9E4-74B8-2B97-CC0C401D052A">
                <File Id="file_opcsec_ps"
                      Name="opcsec_ps.dll"
                      Source="$(var.BinDir)\opcsec_ps.dll"
                      KeyPath="yes"
                      SelfRegCost="1" />
            </Component>

            <!-- OPC Server Enumerator (Windows service) -->
            <Component Id="comp_OpcEnum" Guid="4695E177-FFA9-6706-9772-290B37AD1438">
                <File Id="file_OpcEnum"
                      Name="OpcEnum.exe"
                      Source="$(var.BinDir)\OpcEnum.exe"
                      KeyPath="yes" />
            </Component>

        </StandardDirectory>

        <!--
            x86: OpcCmdPs and OpcDxPs go to Common Files\OPC Foundation\Bin
        -->
        <StandardDirectory Id="CommonFilesFolder">
            <Directory Id="OPCFoundationFolder" Name="OPC Foundation">
                <Directory Id="OPCBinFolder" Name="Bin">

                    <Component Id="comp_OpcCmdPs" Guid="B9011D62-73A6-23AF-A2D1-F979014F853B">
                        <File Id="file_OpcCmdPs"
                              Name="OpcCmdPs.dll"
                              Source="$(var.BinDir)\OpcCmdPs.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                    <Component Id="comp_OpcDxPs" Guid="8D21BDBF-0135-5954-A9BF-4911EAD28B2B">
                        <File Id="file_OpcDxPs"
                              Name="OpcDxPs.dll"
                              Source="$(var.BinDir)\OpcDxPs.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                </Directory>

            </Directory>
        </StandardDirectory>

        <!-- OpcEnum: register as Windows service on install, unregister on uninstall -->
        <CustomAction Id="RegisterOpcEnum"
                      FileRef="file_OpcEnum"
                      ExeCommand="/Service"
                      Execute="deferred"
                      Impersonate="no"
                      Return="check" />

        <CustomAction Id="UnregisterOpcEnum"
                      FileRef="file_OpcEnum"
                      ExeCommand="/UnRegServer"
                      Execute="deferred"
                      Impersonate="no"
                      Return="check" />

        <!-- Condition on the OpcEnum COMPONENT action state, not the product
             install state. "$comp = 3" = component is being installed (local),
             "$comp = 2" = component is being removed. Conditioning on
             "NOT Installed" / REMOVE="ALL" assumes the module is always part of the
             transaction, which is false when it lives in an optional feature: the
             action would fire while the file is not marked for install/removal,
             producing error 2753 ("file not marked for installation"). The merge
             engine appends the module signature to the component reference here, so
             the merged condition becomes "$comp_OpcEnum.<ModuleSig> = 3". -->
        <InstallExecuteSequence>
            <Custom Action="RegisterOpcEnum" After="InstallFiles"
                    Condition="$comp_OpcEnum = 3" />
            <Custom Action="UnregisterOpcEnum" Before="RemoveFiles"
                    Condition="$comp_OpcEnum = 2" />
        </InstallExecuteSequence>

        <?else?>
        <!--
            x64: all 8 DLLs + OpcCategoryManager.exe go to Common Files\OPC Foundation\Bin
            (CommonFiles64Folder is not a system folder, so no SharedDLLs cleanup
            is needed here - the broken 3.1.1.89 only corrupted the x86 SystemFolder
            entries.)
        -->
        <StandardDirectory Id="CommonFiles64Folder">
            <Directory Id="OPCFoundationFolder" Name="OPC Foundation">
                <Directory Id="OPCBinFolder" Name="Bin">

                    <Component Id="comp_opccomn_ps" Guid="3B994FAF-50B0-664A-7327-84C53151DC3A">
                        <File Id="file_opccomn_ps"
                              Name="opccomn_ps.dll"
                              Source="$(var.BinDir)\opccomn_ps.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                    <Component Id="comp_opcproxy" Guid="A930A8B0-CD04-98D6-D8CC-28B2B86C6FEA">
                        <File Id="file_opcproxy"
                              Name="opcproxy.dll"
                              Source="$(var.BinDir)\opcproxy.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                    <Component Id="comp_opc_aeps" Guid="BF39502E-19E8-0AF9-6A17-33FCB8556882">
                        <File Id="file_opc_aeps"
                              Name="opc_aeps.dll"
                              Source="$(var.BinDir)\opc_aeps.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                    <Component Id="comp_opcbc_ps" Guid="8EF6E68D-0D6E-E29C-8521-885632687BCD">
                        <File Id="file_opcbc_ps"
                              Name="opcbc_ps.dll"
                              Source="$(var.BinDir)\opcbc_ps.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                    <Component Id="comp_OpcCmdPs" Guid="2A707F0E-D9FE-9DAE-01F0-C7598CB77D14">
                        <File Id="file_OpcCmdPs"
                              Name="OpcCmdPs.dll"
                              Source="$(var.BinDir)\OpcCmdPs.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                    <Component Id="comp_OpcDxPs" Guid="8B1F066C-7B26-4193-526A-96570BF904EE">
                        <File Id="file_OpcDxPs"
                              Name="OpcDxPs.dll"
                              Source="$(var.BinDir)\OpcDxPs.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                    <Component Id="comp_opchda_ps" Guid="2084B775-59CC-B88F-99BF-B82FEFD263F4">
                        <File Id="file_opchda_ps"
                              Name="opchda_ps.dll"
                              Source="$(var.BinDir)\opchda_ps.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                    <Component Id="comp_opcsec_ps" Guid="F59E37D7-AA01-9651-122D-AD3ECBCFEBDB">
                        <File Id="file_opcsec_ps"
                              Name="opcsec_ps.dll"
                              Source="$(var.BinDir)\opcsec_ps.dll"
                              KeyPath="yes"
                              SelfRegCost="1" />
                    </Component>

                    <!-- OPC Category Manager (COM local server for x64 category enumeration) -->
                    <Component Id="comp_OpcCategoryManager" Guid="39F22912-1A3C-C44E-EF19-778291394A31">
                        <File Id="file_OpcCategoryManager"
                              Name="OpcCategoryManager.exe"
                              Source="$(var.BinDir)\OpcCategoryManager.exe"
                              KeyPath="yes" />
                    </Component>

                </Directory>

            </Directory>
        </StandardDirectory>

        <!-- OpcCategoryManager: register as COM server on install, unregister on uninstall -->
        <!-- Action IDs kept short: WiX appends the 37-char module signature
             (".<ModuleGuid>") to each, and ModuleInstallExecuteSequence.Action
             caps at 64 chars (ICE03). -->
        <CustomAction Id="RegisterOpcCatMgr"
                      FileRef="file_OpcCategoryManager"
                      ExeCommand="/RegServer"
                      Execute="deferred"
                      Impersonate="no"
                      Return="check" />

        <CustomAction Id="UnregisterOpcCatMgr"
                      FileRef="file_OpcCategoryManager"
                      ExeCommand="/UnRegServer"
                      Execute="deferred"
                      Impersonate="no"
                      Return="check" />

        <!-- Condition on the OpcCategoryManager COMPONENT action state, not the
             product install state - same fix as OpcEnum (x86) above. "$comp = 3" =
             being installed, "$comp = 2" = being removed. Avoids error 2753 when the
             module is in an optional feature that is not part of the transaction. -->
        <InstallExecuteSequence>
            <Custom Action="RegisterOpcCatMgr" After="InstallFiles"
                    Condition="$comp_OpcCategoryManager = 3" />
            <Custom Action="UnregisterOpcCatMgr" Before="RemoveFiles"
                    Condition="$comp_OpcCategoryManager = 2" />
        </InstallExecuteSequence>

        <?endif?>

    </Module>

</Wix>
