<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- nuget.org is still needed for the transitive dependencies -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- local OPC Classic .NET API packages produced by DotNetRCWs\build.ps1 -->
    <add key="OpcNetApi" value=".\dist" />
   </packageSources>
</configuration>